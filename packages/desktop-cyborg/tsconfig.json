{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "main.ts",
    "pty-host-shutdown.ts",
    "pty-host-orphan-reaper.ts",
    "preload.cts",
    "desktop-error-report.ts",
    "login-shell-env.ts",
    "desktop-utils.ts",
    "daemon-manager.ts",
    "desktop-clipboard.ts",
    "daemon-runtime-paths.ts",
    "daemon-entrypoint-launcher.ts",
    "daemon-entrypoint-runner.ts",
    "daemon-package-paths.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
