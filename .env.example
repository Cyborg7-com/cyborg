# Cyborg7 Development Environment
# Copy to .env and adjust as needed: cp .env.example .env
#
# Cyborg7 uses its own env vars (CYBORG_*) so it can coexist with
# a stock Paseo daemon on the same machine. The dev scripts map
# CYBORG_* to Paseo internals automatically.

# ── Daemon ──────────────────────────────────────────────
# Listen address (default: 127.0.0.1:6780 — Paseo uses 6767)
CYBORG_LISTEN=127.0.0.1:6780

# Runtime state directory (default: ~/.cyborg7 — Paseo uses ~/.paseo)
# CYBORG_HOME=~/.cyborg7

# CORS origins (default: * in dev)
# CYBORG_CORS_ORIGINS=http://localhost:5173

# ── Database ────────────────────────────────────────────
# PostgreSQL connection (optional). Leave empty for solo mode (SQLite only).
# Solo mode is fully functional for single-machine use.
# DATABASE_URL=postgresql://user:pass@host:5432/cyborg7

# ── Auth ────────────────────────────────────────────────
# JWT secret for Cyborg7 tokens. In dev mode a default is used automatically.
# CYBORG7_JWT_SECRET=change-me-in-production

# ── Relay (multi-daemon) ────────────────────────────────
# WebSocket URL of the workspace relay broker (optional).
# Only needed when connecting multiple daemons together.
# CYBORG_RELAY_URL=ws://relay.example.com:9100
# CYBORG_RELAY_TOKEN=shared-relay-secret

# ── AI Providers ────────────────────────────────────────
# At least one provider key is needed for agents to work.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Observability ───────────────────────────────────────
# Pydantic Logfire write token (server-side only — relay + our own daemons).
# Absent ⇒ observability runs in no-op mode (local/dev/end-user installs stay silent).
# LOGFIRE_TOKEN=
